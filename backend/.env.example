# Ключ от OpenAI API (требуется для GPT-4o)
OPENAI_API_KEY=your_openai_key_here

# Ключ от Google AI (требуется для Gemini Flash/Pro OCR)
GEMINI_API_KEY=your_gemini_key_here

# Список разрешенных доменов для CORS (через запятую)
# По умолчанию для разработки: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
