{
  "name": "egcheck-root",
  "version": "1.0.0",
  "description": "Монорепозиторий для проверки сочинений ЕГЭ",
  "scripts": {
    "install:all": "npm install && cd react-frontend && npm install",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd react-frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
